# Environnements
# Valeurs : dev | staging | prod
APP_ENV=dev
APP_NAME=ADAM
APP_VERSION=0.1.0

# BDD
POSTGRES_USER=adam
POSTGRES_DB=adam_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_PASSWORD=PASSWORD
# DATABASE_URL=postgresql+asyncpg://adam:adam_dev_password@localhost:5432/adam_db

# API FastAPI
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
API_TITLE="ADAM API"
API_CORS_ORIGINS=http://localhost:4200

# Auth
API_DISABLE_JWT_VALIDATION=true

# Secret JWT
JWT_SECRET_KEY=changeme_use_a_strong_random_secret_in_prod
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Stockage fichiers (PVC)
PVC_MOUNT_PATH=./data/pvc

# Logging
LOG_LEVEL=DEBUG
LOG_FORMAT=json

# OCR
OCR_MOCK_ENABLED=true
OCR_MOCK_CONFIDENCE=0.95
OCR_TIMEOUT_SECONDS=30

# Auth service machine
INTERNAL_AUTH_ENABLED=false
INTERNAL_API_KEY=changeme_internal_key
